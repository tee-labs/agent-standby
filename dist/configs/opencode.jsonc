          }
        },
        "glm-5": {
          "name": "glm-5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "qwen3.5:397b": {
          "name": "qwen3.5:397b",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "qwen3-coder:480b": {
          "name": "qwen3-coder:480b",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "kimi-k2.6": {
          "name": "kimi-k2.6",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "ark-code-latest": {
          "name": "ark-code-latest",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:API_KEY}",
        "baseURL": "https://airfly.dpdns.org/v1"
      }
    }
  },
  "plugin": ["oh-my-openagent@latest", "@tarquinen/opencode-dcp@latest", "context-mode"],
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "{env:CONTEXT7_API_KEY}"],
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    }
  }
}
