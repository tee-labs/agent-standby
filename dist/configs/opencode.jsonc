          }
        },
        "minimaxai/minimax-m2.5": {
          "name": "minimaxai/minimax-m2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "minimaxai/minimax-m2.7": {
          "name": "minimaxai/minimax-m2.7",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "moonshotai/kimi-k2.5": {
          "name": "moonshotai/kimi-k2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "minimax-m2.7": {
          "name": "minimax-m2.7",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "glm-5.1": {
          "name": "glm-5.1",
          "modalities": {
            "input": ["text", "image"],
