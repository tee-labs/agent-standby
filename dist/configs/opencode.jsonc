{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "autoshare": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "--config", "./.prettierrc", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".json", ".jsonc", ".css", ".md", ".yml", ".yaml"]
    }
  },
  "logLevel": "DEBUG",
  // "enabled_providers": ["x-openai", "x-google", "x-anthropic"],
  "small_model": "x-openai/modelscope/deepseek-ai/DeepSeek-V3.2",
  "provider": {
    "x-openai": {
      "models": {
        "modelscope/deepseek-ai/DeepSeek-V3.2": {
          "name": "modelscope/deepseek-ai/DeepSeek-V3.2",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "MiniMax/MiniMax-M2.5": {
          "name": "MiniMax/MiniMax-M2.5",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "MiniMax/MiniMax-M2.7": {
          "name": "MiniMax/MiniMax-M2.7",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "moonshotai/Kimi-K2.5": {
          "name": "moonshotai/Kimi-K2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "ZhipuAI/GLM-5": {
          "name": "ZhipuAI/GLM-5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "ZhipuAI/GLM-5.1": {
          "name": "ZhipuAI/GLM-5.1",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "LongCat-Flash-Chat": {
          "name": "LongCat-Flash-Chat",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "LongCat-Flash-Thinking": {
          "name": "LongCat-Flash-Thinking",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "LongCat-Flash-Lite": {
          "name": "LongCat-Flash-Lite",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "LongCat-Pro-Preview": {
          "name": "LongCat-Pro-Preview",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "LongCat-Flash-Chat-2602-Exp": {
          "name": "LongCat-Flash-Chat-2602-Exp",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "Sphynx": {
          "name": "Sphynx",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "z-ai/glm4.7": {
          "name": "z-ai/glm4.7",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "z-ai/glm5": {
          "name": "z-ai/glm5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "z-ai/glm-5.1": {
