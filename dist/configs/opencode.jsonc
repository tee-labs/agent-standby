{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "autoshare": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 4096
  },
  "experimental": {
    "batch_tool": true,
    "openTelemetry": false
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "--config", "./.prettierrc", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".json", ".jsonc", ".css", ".md", ".yml", ".yaml"]
    }
  },
  "logLevel": "DEBUG",
  // "enabled_providers": ["x-openai", "x-google", "x-anthropic"],
  "small_model": "x-openai/ollama/gemma4:31b",
  // curl https://airfly.dpdns.org/v1/models   -H "Authorization: Bearer APIKEY"   -H "Content-Type: application/json" | jq .data[].id | awk '{print $1":{\"name\":"$1",\"modalities\":{\"input\": [\"text\"], \"output\": [\"text\"]}},"}'
  "provider": {
    "x-openai": {
      "models": {
	  "ollama/gemma4:31b":{"name":"ollama/gemma4:31b","modalities":{"input": ["text"], "output": ["text"]}},
	  "ollama/glm-4.7":{"name":"ollama/glm-4.7","modalities":{"input": ["text"], "output": ["text"]}},
	  "ollama/minimax-m2.5":{"name":"ollama/minimax-m2.5","modalities":{"input": ["text"], "output": ["text"]}},
	  "ollama/qwen3-vl:235b":{"name":"ollama/qwen3-vl:235b","modalities":{"input": ["text"], "output": ["text"]}},
	  "ollama/qwen3-coder:480b":{"name":"ollama/qwen3-coder:480b","modalities":{"input": ["text"], "output": ["text"]}},
	  "ollama/qwen3-vl:235b-instruct":{"name":"ollama/qwen3-vl:235b-instruct","modalities":{"input": ["text"], "output": ["text"]}},
	  "sensenova/sensenova-6.7-flash-lite":{"name":"sensenova/sensenova-6.7-flash-lite","modalities":{"input": ["text"], "output": ["text"]}},
	  "sensenova/sensenova-u1-fast":{"name":"sensenova/sensenova-u1-fast","modalities":{"input": ["text"], "output": ["text"]}},
	  "sensenova/deepseek-v4-flash":{"name":"sensenova/deepseek-v4-flash","modalities":{"input": ["text"], "output": ["text"]}},
	  "opencode/big-pickle":{"name":"opencode/big-pickle","modalities":{"input": ["text"], "output": ["text"]}},
	  "opencode/minimax-m2.5-free":{"name":"opencode/minimax-m2.5-free","modalities":{"input": ["text"], "output": ["text"]}},
	  "openrouter/openrouter/free":{"name":"openrouter/openrouter/free","modalities":{"input": ["text"], "output": ["text"]}},
	  "openrouter/minimax/minimax-m2.5:free":{"name":"openrouter/minimax/minimax-m2.5:free","modalities":{"input": ["text"], "output": ["text"]}},
	  "openrouter/openai/gpt-oss-120b:free":{"name":"openrouter/openai/gpt-oss-120b:free","modalities":{"input": ["text"], "output": ["text"]}},
	  "openrouter/google/gemma-4-31b-it:free":{"name":"openrouter/google/gemma-4-31b-it:free","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/z-ai/glm-5.1":{"name":"nvidia/z-ai/glm-5.1","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/qwen/qwen3-coder-480b-a35b-instruct":{"name":"nvidia/qwen/qwen3-coder-480b-a35b-instruct","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/qwen/qwen3.5-397b-a17b":{"name":"nvidia/qwen/qwen3.5-397b-a17b","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/qwen/qwen3.5-122b-a10b":{"name":"nvidia/qwen/qwen3.5-122b-a10b","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/minimaxai/minimax-m2.5":{"name":"nvidia/minimaxai/minimax-m2.5","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/nvidia/nemotron-3-super-120b-a12b":{"name":"nvidia/nvidia/nemotron-3-super-120b-a12b","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/nvidia/nemotron-3-nano-omni-30b-a3b-reasoning":{"name":"nvidia/nvidia/nemotron-3-nano-omni-30b-a3b-reasoning","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/deepseek-ai/deepseek-v4-flash":{"name":"nvidia/deepseek-ai/deepseek-v4-flash","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/depseek-ai/deepseek-v4-pro":{"name":"nvidia/deepseek-ai/deepseek-v4-pro","modalities":{"input": ["text"], "output": ["text"]}},
	  "nvidia/minimaxai/minimax-m2.7":{"name":"nvidia/minimaxai/minimax-m2.7","modalities":{"input": ["text"], "output": ["text"]}},
	  "doubao/ark-code-latest":{"name":"doubao/ark-code-latest","modalities":{"input": ["text"], "output": ["text"]}}
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:API_KEY}",
        "baseURL": "https://airfly.dpdns.org/v1"
      }
    }
  },
  "plugin": ["oh-my-openagent@latest", "@tarquinen/opencode-dcp@latest", "context-mode"],
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "{env:CONTEXT7_API_KEY}"],
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": ["npx", "-y", "context-mode"]
    }
  },
  "lsp": {
    "jdtls": {
      "disabled": false,
      "command": ["jdtls"],
      "env": {
        "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk-amd64"
      }
    }
  }
}
